{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Configuration Schema",
  "description": "Schema for GitHub repository security configurations",
  "type": "object",
  "required": ["scope", "owner", "repository"],
  "properties": {
    "scope": {
      "type": "string",
      "enum": ["repo"],
      "description": "Configuration scope (must be 'repo' for repository config)"
    },
    "owner": {
      "type": "string",
      "description": "Repository owner (organization or user)",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "description": "Repository name",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Configuration description"
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private"],
      "description": "Repository visibility"
    },
    "branch_protection": {
      "type": "object",
      "description": "Branch protection ruleset configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Ruleset name"
        },
        "target": {
          "type": "string",
          "enum": ["branch"],
          "description": "Ruleset target"
        },
        "enforcement": {
          "type": "string",
          "enum": ["active", "disabled", "evaluate"],
          "description": "Ruleset enforcement level"
        },
        "bypass_actors": {
          "type": "array",
          "description": "Actors that can bypass this ruleset"
        },
        "conditions": {
          "type": "object",
          "description": "Ruleset conditions"
        },
        "rules": {
          "type": "array",
          "description": "Ruleset rules"
        }
      },
      "required": ["name", "target"]
    },
    "files": {
      "type": "array",
      "description": "Files to create in repository",
      "items": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path (e.g., '.github/CODEOWNERS')"
          },
          "content": {
            "type": "string",
            "description": "File content"
          },
          "message": {
            "type": "string",
            "description": "Commit message"
          }
        }
      }
    },
    "webhooks": {
      "type": "array",
      "description": "Webhooks to configure",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook URL"
          },
          "events": {
            "type": "array",
            "description": "Events to trigger webhook"
          },
          "active": {
            "type": "boolean",
            "description": "Whether webhook is active"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
