{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team Configuration Schema",
  "description": "Schema for GitHub team management configurations",
  "type": "object",
  "required": ["scope", "organization", "team_name"],
  "properties": {
    "scope": {
      "type": "string",
      "enum": ["team"],
      "description": "Configuration scope (must be 'team' for team config)"
    },
    "organization": {
      "type": "string",
      "description": "GitHub organization name",
      "minLength": 1
    },
    "team_name": {
      "type": "string",
      "description": "Team name",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Team description"
    },
    "privacy": {
      "type": "string",
      "enum": ["closed", "open"],
      "description": "Team privacy setting (closed = members only, open = all org members)"
    },
    "parent_team_id": {
      "type": "integer",
      "description": "Parent team ID for nested teams"
    },
    "repositories": {
      "type": "array",
      "description": "Repository access configuration",
      "items": {
        "type": "object",
        "required": ["name", "permission"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Repository name"
          },
          "permission": {
            "type": "string",
            "enum": ["pull", "push", "admin", "maintain", "triage"],
            "description": "Permission level for this repository"
          }
        }
      }
    },
    "members": {
      "type": "array",
      "description": "Team members",
      "items": {
        "type": "object",
        "required": ["username"],
        "properties": {
          "username": {
            "type": "string",
            "description": "GitHub username"
          },
          "role": {
            "type": "string",
            "enum": ["member", "maintainer"],
            "description": "Role in team"
          }
        }
      }
    },
    "notification_setting": {
      "type": "string",
      "enum": ["notifications_enabled", "notifications_disabled"],
      "description": "Notification settings for team"
    }
  },
  "additionalProperties": false
}
